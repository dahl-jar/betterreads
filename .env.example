# Copy to .env for local development. Never commit the populated .env file.

# Database (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=betterreads
DB_USERNAME=betterreads
DB_PASSWORD=betterreads

# OpenLibrary integration
OPENLIBRARY_BASE_URL=https://openlibrary.org
OPENLIBRARY_SEARCH_LIMIT=20
OPENLIBRARY_CONNECT_TIMEOUT=5000
OPENLIBRARY_READ_TIMEOUT=10000

# JWT auth (generate a random 256-bit secret for production)
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_ISSUER=betterreads
JWT_EXPIRATION_MINUTES=60

# Server
SERVER_PORT=8080

# Logging level for the application package
LOG_LEVEL_BETTERREADS=INFO
