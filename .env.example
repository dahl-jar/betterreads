# Copy to .env for local development. Never commit the populated .env file.

# Database connection.
# DB_USERNAME / DB_PASSWORD are the migration owner (Flyway runs as this role).
# DB_APP_USERNAME / DB_APP_PASSWORD are the runtime app role (Spring Boot uses these).
# V10 creates `betterreads_app` and grants it CRUD on data tables only.
# Generate DB_APP_PASSWORD via `openssl rand -base64 24`.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=betterreads
DB_USERNAME=betterreads
DB_PASSWORD=replace-with-owner-password
DB_APP_USERNAME=betterreads_app
DB_APP_PASSWORD=replace-with-strong-random-password

# JDBC SSL mode. Local Docker Postgres uses `disable`; a remote Postgres uses `require`.
DB_SSL_MODE=disable

# Flyway migration target. `latest` runs all migrations. Pin to a specific
# version (e.g. `9`) only if a host can't run a later migration.
SPRING_FLYWAY_TARGET=latest

# OpenLibrary integration (keyless; OpenLibrary asks callers to identify themselves)
OPENLIBRARY_BASE_URL=https://openlibrary.org
OPENLIBRARY_CONTACT_EMAIL=replace-with-your-contact-email
OPENLIBRARY_CONNECT_TIMEOUT=5000
OPENLIBRARY_READ_TIMEOUT=10000

GOOGLE_BOOKS_BASE_URL=https://www.googleapis.com/books/v1
GOOGLE_BOOKS_API_KEY=replace-with-google-books-api-key
GOOGLE_BOOKS_CONNECT_TIMEOUT=5000
GOOGLE_BOOKS_READ_TIMEOUT=10000

# Hardcover integration (GraphQL; raw token, the client prepends "Bearer ")
HARDCOVER_BASE_URL=https://api.hardcover.app/v1/graphql
HARDCOVER_BEARER_TOKEN=replace-with-hardcover-api-token
HARDCOVER_CONNECT_TIMEOUT=5000
HARDCOVER_READ_TIMEOUT=10000

# JWT auth (generate a random 256-bit secret for production)
JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_ISSUER=betterreads
JWT_EXPIRATION_MINUTES=120
JWT_REFRESH_EXPIRATION_DAYS=30

# Refresh-token cookie. Production stays Secure=true. For local HTTP dev set
# AUTH_REFRESH_COOKIE_SECURE=false so the browser still accepts the cookie.
AUTH_REFRESH_COOKIE_SECURE=true

# Server
SERVER_PORT=8080

# Logging level for the application package
LOG_LEVEL_BETTERREADS=INFO

# CORS allow list (csv of exact origins). Empty = no browser origin allowed.
APP_CORS_ALLOWED_ORIGINS=

# Cloudflare Access JWT validation for the management endpoints. Filled in at
# deploy time, after the Access application is created and its AUD is known.
# Empty values disable the validation; the management chain stays permitAll
# behind the localhost-only port binding. See docs/how-to/cloudflare-tunnel.md.
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_TEAM_DOMAIN=

# Outbound mail (Resend). MAIL_FROM must be on a Resend-verified domain.
# APP_BASE_URL is the public origin embedded in reset links; users click
# ${APP_BASE_URL}/reset-password?token=... in the email.
MAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-resend-api-key
MAIL_FROM=no-reply@betterreadsapp.com
APP_BASE_URL=https://betterreadsapp.com
