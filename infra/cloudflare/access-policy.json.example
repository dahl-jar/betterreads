{
  "application": {
    "name": "betterreads-metrics",
    "type": "self_hosted",
    "domain": "metrics.betterreadsapp.com",
    "session_duration": "24h",
    "auto_redirect_to_identity": false,
    "allowed_idps": [],
    "cors_headers": {
      "allow_all_methods": false,
      "allow_credentials": false,
      "max_age": 0
    },
    "skip_interstitial": false,
    "tags": ["betterreads", "actuator"]
  },
  "policies": [
    {
      "name": "owen-only",
      "decision": "allow",
      "precedence": 1,
      "include": [
        {
          "email": {
            "email": "<your-email>"
          }
        }
      ]
    },
    {
      "name": "prometheus-service-token",
      "decision": "non_identity",
      "precedence": 2,
      "include": [
        {
          "service_token": {
            "token_id": "<service-token-id>"
          }
        }
      ]
    }
  ]
}
