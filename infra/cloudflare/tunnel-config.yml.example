#
# cloudflared tunnel config for the BetterReads VM.
#
# Copy to /etc/cloudflared/config.yml on the VM after running
# `cloudflared tunnel create betterreads`. Replace <tunnel-id> and the
# hostnames with real values. The credentials file is whatever
# `cloudflared tunnel create` wrote, usually under ~/.cloudflared/.
#
# Two ingress rules: the metrics hostname goes to the management port
# behind Access; the api hostname goes to the public app port.
# The trailing 404 catches anything else so a misconfigured DNS
# record doesn't accidentally leak a service.
#

tunnel: <tunnel-id>
credentials-file: /home/ubuntu/.cloudflared/<tunnel-id>.json

ingress:
  - hostname: metrics.betterreadsapp.com
    service: http://127.0.0.1:8081

  - hostname: api.betterreadsapp.com
    service: http://127.0.0.1:8080
    originRequest:
      connectTimeout: 10s
      noHappyEyeballs: true

  - service: http_status:404
