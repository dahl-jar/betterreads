#
# Postgres backup cron line for the production VM. Goes on the host crontab,
# not inside the postgres container.
#
# Install with: sudo crontab -e (as root, since pg-backup.sh runs as root to
# read /opt/betterreads/.env and run docker exec)
# then paste the line below.
#
# Fires at 03:00 UTC every day. The script handles the daily-vs-weekly logic
# itself; Sundays produce both. stdout and stderr go to syslog tagged
# "betterreads-backup", which means journalctl -t betterreads-backup shows
# every run. Cron only mails MAILTO if the script exits non-zero.

MAILTO=owen@betterreadsapp.com
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

0 3 * * * set -a && source /opt/betterreads/.env && set +a && /opt/betterreads/pg-backup.sh 2>&1 | logger -t betterreads-backup
