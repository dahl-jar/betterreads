# syntax=docker/dockerfile:1
# Config is injected at runtime via k8s ConfigMap/Secret env, never baked into the image.
FROM eclipse-temurin:25-jre
WORKDIR /app
RUN useradd --system --uid 10001 --no-create-home betterreads
COPY build/libs/betterreads-backend-0.0.1-SNAPSHOT.jar /app/app.jar
USER 10001
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
