<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
      BetterReads dependency-check suppression policy:
      - Keep this file empty unless a finding is confirmed as a false positive or temporarily accepted risk.
      - Prefer the narrowest matcher possible: sha1 or gav first, packageUrl next, broad file regex last.
      - Every suppression must include notes that explain why it exists and who verified it.
      - Temporary suppressions must use the `until` attribute and point to a tracking issue.
      - Remove suppressions as soon as the dependency is upgraded or the false positive is fixed upstream.
    -->
    <suppress>
        <notes><![CDATA[
            Guava 30.1.1 reaches the tree only through the ErrorProne dataflow shading on the
            errorprone configuration. ErrorProne runs at compile time and ships nothing, so
            CVE-2023-2976 (temp-directory file disclosure) cannot run in the application.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava@30\.1\.1.*$</packageUrl>
        <cve>CVE-2023-2976</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            plexus-utils 3.3.0 is a build-tool transitive that stays on the build classpath, so
            CVE-2025-67030 cannot run in the application.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.codehaus\.plexus/plexus-utils@3\.3\.0$</packageUrl>
        <cve>CVE-2025-67030</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            Rhino 1.7.15 is pulled only by the dependency-check plugin's own RetireJS analyzer, so
            CVE-2025-66453 cannot run in the application.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.mozilla/rhino@1\.7\.15$</packageUrl>
        <cve>CVE-2025-66453</cve>
    </suppress>
</suppressions>
