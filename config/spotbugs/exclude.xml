<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!--
      SPRING_ENDPOINT is informational. FindSecBugs flags every @RequestMapping method
      so a reviewer can audit it. We already enforce auth via SecurityConfig and treat
      controllers as scrutinized by code review; the noise outweighs the value.
    -->
    <Match>
        <Bug pattern="SPRING_ENDPOINT"/>
    </Match>

    <!--
      SERVLET_HEADER fires whenever request headers are read. JWT auth requires reading
      Authorization on every request; suppressing globally is correct because every
      auth-aware filter would otherwise need an inline suppression with the same reason.
    -->
    <Match>
        <Bug pattern="SERVLET_HEADER"/>
    </Match>

    <!--
      THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION on test classes only. MockMvc.perform()
      itself declares 'throws Exception'; rewrapping in the test isn't useful when the
      test fails fast on any throw anyway.
    -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_CLAUSE_BASIC_EXCEPTION"/>
        <Class name="~.*Test(\$.+)?"/>
    </Match>

    <!--
      EI_EXPOSE_REP2 on Spring services that hold injected ObjectMapper, repositories, or
      other singleton beans. Defensive copies are wrong here: the injected references are
      Spring-managed singletons, never mutated post-construction, and shared across the
      application by design. Suppression is narrow to the mail.outbox package and the one
      auth service that talks to it.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Package name="com.betterreads.mail.outbox"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.auth.passwordreset.PasswordResetService"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.auth.emailverification.EmailVerificationService"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Package name="com.betterreads.auth.deletion"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.auth.ratelimit.RateLimitFilter"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Package name="com.betterreads.catalog.read.sse"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.catalog.controller.BookController"/>
    </Match>

    <!--
      EI_EXPOSE_REP / EI_EXPOSE_REP2 on JPA entities. Hibernate tracks the live collection
      instance for dirty-checking and cascade; returning or accepting a defensive copy would
      break orphan removal and managed-collection semantics. Entities are not value objects.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="com.betterreads.catalog.entity"/>
    </Match>

    <!--
      NP_UNWRITTEN_FIELD / UWF_UNWRITTEN_FIELD on @Autowired test fields. Spring sets these
      reflectively, which SpotBugs cannot see, so it reads them as never written. Scoped to
      test classes only.
    -->
    <Match>
        <Bug pattern="NP_UNWRITTEN_FIELD,UWF_UNWRITTEN_FIELD"/>
        <Class name="~.*Test(\$.+)?"/>
    </Match>

    <!--
      EI_EXPOSE_REP2 on integration clients (enrichment under .client, discovery under
      .discovery) and the shared SRU/REST gateways, all holding their injected WebClient and
      mapper. These are Spring-managed singletons, never mutated after construction and shared
      by design. A defensive copy is meaningless for a WebClient. Same rationale as the
      mail.outbox and auth-service suppressions above.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Package name="~com\.betterreads\.integration\..*\.(client|discovery)"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.integration.loc.LocSru"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="com.betterreads.integration.wikidata.WikidataApi"/>
    </Match>

    <!--
      CRLF_INJECTION_LOGS on the opt-in seed and pipeline verification. The logged title is passed
      through LogSanitizer.forLog, but FindSecBugs does not recognize that helper as a sanitizer
      through the static-import indirection in these classes (it accepts the same helper in the
      integration clients). Test-only verification code; the value is genuinely scrubbed.
    -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Class name="com.betterreads.catalog.source.CatalogOpenLibrarySeedVerification"/>
    </Match>
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Class name="com.betterreads.catalog.pipeline.CatalogPipelineLiveE2eTest"/>
    </Match>
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Class name="com.betterreads.catalog.pipeline.CatalogPipelineLocalDbVerification"/>
    </Match>

    <!--
      CRLF_INJECTION_LOGS on the catalog source fan-out. These warn lines log a BookFieldSource enum
      constant and an exception class name, never an external string. FindSecBugs taints the whole
      log call because the surrounding objects came from an HTTP response, but neither logged value
      can carry CRLF.
    -->
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Class name="com.betterreads.catalog.service.pipeline.SourceCollector"/>
    </Match>
    <Match>
        <Bug pattern="CRLF_INJECTION_LOGS"/>
        <Class name="com.betterreads.catalog.service.pipeline.CatalogSearchService"/>
    </Match>

    <!--
      IMPROPER_UNICODE on the shared title-versus-query comparison. FindSecBugs flags any
      case-insensitive comparison as a Unicode case-folding risk. The comparison here is a book
      title against a free-form search query for a best-effort drift check, used by the OpenLibrary
      client and the standalone-fallback staging; it is not a security token or authorization
      decision, so a Unicode collision has no exploitable consequence.
    -->
    <Match>
        <Bug pattern="IMPROPER_UNICODE"/>
        <Class name="com.betterreads.common.util.TextMatch"/>
    </Match>
</FindBugsFilter>
